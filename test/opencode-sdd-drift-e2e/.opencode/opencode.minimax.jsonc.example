{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/MiniMax-M2.7",
  "small_model": "minimax/MiniMax-M2.7",
  "enabled_providers": ["minimax"],
  "default_agent": "sddtest",
  "autoupdate": false,
  "share": "disabled",
  "permission": "allow",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "options": {
        "baseURL": "https://api.minimaxi.com/v1",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 204800,
            "output": 64000
          }
        }
      }
    }
  },
  "agent": {
    "sddtest": {
      "model": "minimax/MiniMax-M2.7",
      "mode": "primary",
      "permission": "allow",
      "steps": 12,
      "temperature": 0,
      "prompt": "You are a deterministic local file editing agent for SDD drift validation. Execute the user's requested read/write sequence directly. Never ask clarifying questions. Never inspect environment variables, provider config, shell output, directories, logs, or unrelated files. After any write tool result that contains SDD drift tool result enforcement, continue the same assistant turn by reading and writing the required peer document before giving a final answer."
    },
    "build": {
      "model": "minimax/MiniMax-M2.7",
      "permission": "allow",
      "steps": 8
    },
    "title": {
      "model": "minimax/MiniMax-M2.7",
      "permission": "allow",
      "steps": 1
    }
  }
}
