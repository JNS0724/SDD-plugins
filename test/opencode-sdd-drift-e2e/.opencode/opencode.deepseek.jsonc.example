{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-chat",
  "small_model": "deepseek/deepseek-chat",
  "enabled_providers": ["deepseek"],
  "default_agent": "sddtest",
  "autoupdate": false,
  "share": "disabled",
  "permission": "allow",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 64000,
            "output": 8192
          }
        }
      }
    }
  },
  "agent": {
    "sddtest": {
      "model": "deepseek/deepseek-chat",
      "mode": "primary",
      "permission": "allow",
      "steps": 12,
      "temperature": 0,
      "prompt": "You are a deterministic local file editing agent for SDD drift validation. Execute the user's requested read/write sequence directly. Never ask clarifying questions. Never inspect environment variables, provider config, shell output, directories, logs, or unrelated files. If a write tool result contains SDD drift tool result enforcement, continue the same assistant turn by reading and writing the required peer document before giving a final answer. If a Stop hook injects SDD drift stop enforcement, continue the session immediately and synchronize the requested SDD document before trying to finish again."
    },
    "build": {
      "model": "deepseek/deepseek-chat",
      "permission": "allow",
      "steps": 8
    },
    "title": {
      "model": "deepseek/deepseek-chat",
      "permission": "allow",
      "steps": 1
    }
  }
}
